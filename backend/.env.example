# Configuración del servidor
NODE_ENV=production
PORT=3000

# Configuración de base de datos
# PostgreSQL (Supabase) - Reemplaza con tus datos reales
# IMPORTANTE: Agregar ?sslmode=require al final para forzar SSL y mejorar conectividad
# Ejemplo con tu proyecto: postgresql://postgres:MacBookPro710@db.ixttdxkelassioemefbo.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=postgresql://postgres:MacBookPro710@db.ixttdxkelassioemefbo.supabase.co:5432/postgres?sslmode=require

# OPCIÓN ALTERNATIVA: Variables separadas (usar si DATABASE_URL falla)
# Descomenta estas líneas si tienes problemas de IPv6 con DATABASE_URL
# DB_HOST=db.ixttdxkelassioemefbo.supabase.co
# DB_USER=postgres
# DB_PASSWORD=MacBookPro710
# DB_NAME=postgres
# DB_PORT=5432
# DB_HOST=your_database_host_here
# DB_USER=your_database_user_here
# DB_PASSWORD=your_database_password_here
# DB_NAME=your_database_name_here
# DB_PORT=3306
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=false
# DB_CONNECTION_LIMIT=10
# DB_ACQUIRE_TIMEOUT=60000
# DB_TIMEOUT=60000
# DB_TIMEZONE=+00:00

# Configuración de sesiones (OBLIGATORIO cambiar en producción)
SESSION_SECRET=your_very_secure_secret_key_here_change_in_production

# URLs para CORS en producción
FRONTEND_URL=https://your-app-name.onrender.com
RENDER_EXTERNAL_URL=https://your-app-name.onrender.com

# Configuración adicional para Render
# Render establece automáticamente estas variables:
# RENDER=true
# RENDER_SERVICE_ID=srv-xxxxxxxxxxxxxxxxxxxx
# RENDER_SERVICE_NAME=your-service-name
